{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "build",
      "type": "shell",
      "command": "make",
      "args": ["all"],
      "options": {
        "cwd": "${workspaceFolder}/application"
      }
    },
    {
      "label": "flash",
      "type": "shell",
      "command": "make",
      "args": ["flash"],
      "options": {
        "cwd": "${workspaceFolder}/application"
      }
    },
    {
      "label": "clean",
      "type": "shell",
      "command": "make",
      "args": ["clean"],
      "options": {
        "cwd": "${workspaceFolder}/application"
      }
    },
    {
      "label": "debug",
      "type": "shell",
      "command": "make",
      "args": ["debug"],
      "options": {
        "cwd": "${workspaceFolder}/application"
      }
    },
    {
      "label": "build-flash",
      "dependsOn": ["build", "flash"],
      "dependsOrder": "sequence"
    }
  ]
}